{
  "name": "@fefeding/aicmd",
  "version": "0.1.1",
  "private": false,
  "type": "commonjs",
  "description": "Web SSH 远程终端工具 - 支持 rz/sz 文件传输",
  "repository": {
    "type": "git",
    "url": "https://cnb.cool/yc_null/fshell"
  },
  "main": "view/index.html",
  "files": [
    "bin/",
    "public/",
    "view/",
    "dist/",
    "data/skills",
    "patches",
    "server.js",
    "package.json",
    "README.md"
  ],
  "icon": "public/favicon.ico",
  "window": {
    "title": "fTerm - 远程终端",
    "width": 1200,
    "height": 800,
    "min_width": 800,
    "min_height": 600,
    "resizable": true,
    "show_in_taskbar": true,
    "frame": true,
    "icon": "public/favicon.ico"
  },
  "scripts": {
    "start": "pm2 start server.js --name fterm-server --disable-logs --",
    "restart": "pm2 restart fterm-server --disable-logs --",
    "stop": "pm2 stop fterm-server --",
    "dev": "vite",
    "build": "npm run build-only",
    "preview": "vite preview",
    "build-only": "vite build && npm run build-server",
    "build-server": "tsc -p tsconfig.server.json",
    "type-check": "vue-tsc --noEmit --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "nw:dev": "node scripts/nw-dev.js",
    "nw:build": "node scripts/nw-build.js",
    "nw:build:win": "node scripts/nw-build.js --platform=win",
    "nw:build:osx": "node scripts/nw-build.js --platform=osx",
    "nw:build:linux": "node scripts/nw-build.js --platform=linux"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-pty": "1.2.0-beta.13",
    "ssh2": "^1.17.0",
    "uuid": "^13.0.2",
    "vue-i18n": "^11.4.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@fefeding/eventemitter": "^1.0.5",
    "@fefeding/vite-nunjucks-plugin": "^1.0.2",
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap": "^5.2.10",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.12.4",
    "@types/ssh2": "^1.15.5",
    "@types/vue": "^2.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^13.9.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "jimp": "^1.6.1",
    "js-cookie": "^3.0.7",
    "jsdom": "^26.1.0",
    "nw": "^0.107.0",
    "nw-builder": "^4.17.11",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss": "^8.5.15",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.19",
    "to-ico": "^1.1.5",
    "typescript": "^5.9.3",
    "vite": "latest",
    "vite-plugin-files-copy": "^3.8.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.3.2",
    "zmodem.js": "^0.1.10"
  },
  "bin": {
    "fterm": "bin/fterm.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2",
      "node-pty"
    ],
    "patchedDependencies": {
      "zmodem.js": "patches/zmodem.js.patch"
    }
  }
}
